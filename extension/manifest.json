{
  "manifest_version": 3,
  "name": "daddy's party 🎬",
  "version": "2.1.1",
  "description": "watch movies w ur person, in sync, on literally any site 🎬",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "webNavigation", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "watchparty"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ]
}
